{
  "dataset": "micro_karaoke",
  "category": "micro karaoke",
  "fields": {
    "microphone_type": {
      "description": "Loại micro chuẩn hóa",
      "data_type": "string",
      "possible_values": [
        "wired",
        "wireless"
      ]
    },
    "wireless_band": {
      "description": "Băng tần không dây chuẩn hóa",
      "data_type": "string",
      "possible_values": [
        "2_4_ghz",
        "uhf"
      ]
    },
    "frequency_data_type": {
      "description": "Loại dữ liệu tần số",
      "data_type": "string",
      "possible_values": [
        "audio",
        "rf",
        "rf_and_audio"
      ]
    },
    "distortion_operator": {
      "description": "Cách diễn giải độ méo tiếng",
      "data_type": "string",
      "possible_values": [
        "Bằng hoặc xấp xỉ",
        "Nhỏ hơn"
      ]
    }
  }
}