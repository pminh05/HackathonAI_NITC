APP_ENV=development
LOG_LEVEL=INFO

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=60

CHECKPOINT_DB_PATH=.data/checkpoints.sqlite
CHECKPOINT_BACKEND=sqlite
# For production/Supabase, set CHECKPOINT_BACKEND=postgres and provide this URL.
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@HOST:5432/postgres

API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_PUBLIC_FRONTEND_URL=https://hackathon-ai-nitc-eight.vercel.app
SSE_HEARTBEAT_SECONDS=15
GUARDRAIL_MODE=enforce
GUARDRAIL_OUTPUT_HOLDBACK_CHARS=16

# Optional cross-session personalization. Keep disabled unless every credential below
# is configured. The Mem0 key must never be exposed to the frontend.
MEMORY_ENABLED=false
MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai
MEM0_SEARCH_TOP_K=10
MEM0_SEARCH_THRESHOLD=0.2
MEM0_SEARCH_TIMEOUT_SECONDS=3
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AUTH_TIMEOUT_SECONDS=5

FPT_API_KEY=
FPT_MODEL=Qwen3.6-27B
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_ENABLE_THINKING=false
FPT_TIMEOUT_SECONDS=30
FPT_MAX_RETRIES=0

# Optional LangSmith tracing; LangChain picks these up automatically.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=product-advisor
